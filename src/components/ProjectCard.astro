---
interface Props {
  title: string;
  status?: string;
  description: string;
  href?: string;
  ctaLabel?: string;
  imageSrc?: string;
  imageAlt?: string;
  stack?: { label: string; href: string }[];
  showImage?: boolean;
}

const {
  title,
  status,
  description,
  href,
  ctaLabel = "Open project",
  imageSrc,
  imageAlt = "",
  stack = [],
  showImage = true
} = Astro.props;

const isExternal = href?.startsWith("http");
---

<article class="group grid h-full gap-3 rounded-lg border border-border/50 bg-transparent p-3.5 transition hover:border-accent/30">
  <div class="grid gap-3.5 sm:grid-cols-[56px_1fr]">
    {showImage && (
      <div class="h-14 w-14 overflow-hidden rounded-md border border-border bg-white p-2">
        {imageSrc ? (
          <img class="h-full w-full object-cover" src={imageSrc} alt={imageAlt} loading="lazy" />
        ) : (
          <div class="grid h-full place-items-center bg-[linear-gradient(135deg,var(--surface-strong),var(--surface),color-mix(in_srgb,var(--accent)_14%,var(--surface)))] text-[0.6rem] font-medium uppercase text-muted">
            Project
          </div>
        )}
      </div>
    )}
    <div>
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-base font-semibold text-text">{title}</h3>
        {status && <span class="shrink-0 rounded-full border border-border px-2 py-0.5 text-[0.7rem] font-medium text-muted">{status}</span>}
      </div>
      <div>
        {stack.length > 0 && (
          <ul class="mt-2 flex flex-wrap gap-1.5" aria-label={`${title} stack`}>
            {stack.map((item) => (
              <li>
                <a
                  class="focus-ring inline-flex rounded-full border border-border bg-surface-strong px-2 py-0.5 text-[0.7rem] font-medium text-muted transition hover:border-accent/40 hover:text-accent"
                  href={item.href}
                  target="_blank"
                  rel="noreferrer"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </div>
  <div>
    <p class="text-sm leading-5 text-muted">{description}</p>
    {href && (
      <a
        class="focus-ring mt-2.5 inline-flex w-fit text-xs font-medium text-muted/80 transition hover:text-accent"
        href={href}
        target={isExternal ? "_blank" : undefined}
        rel={isExternal ? "noreferrer" : undefined}
      >
        {ctaLabel} <span class="ml-1" aria-hidden="true">&gt;</span>
      </a>
    )}
  </div>
</article>
