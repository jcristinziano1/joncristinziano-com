---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
---

<div class:list={["max-w-[700px]", align === "center" && "mx-auto text-center"]}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="text-3xl font-semibold tracking-normal text-text md:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-muted md:text-lg">{description}</p>}
</div>
