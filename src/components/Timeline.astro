---
interface Item {
  title: string;
  period: string;
  description: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<ol class="space-y-0">
  {items.map((item) => (
    <li class="grid gap-4 border-l border-border pb-10 pl-6 last:pb-0 md:grid-cols-[180px_1fr] md:gap-10">
      <div>
        <span class="relative -left-[31px] top-1 block h-3 w-3 rounded-full border border-accent bg-background"></span>
        <p class="text-sm font-semibold text-accent">{item.period}</p>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-text">{item.title}</h3>
        <p class="mt-2 leading-7 text-muted">{item.description}</p>
      </div>
    </li>
  ))}
</ol>
