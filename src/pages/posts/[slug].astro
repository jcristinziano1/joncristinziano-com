---
import Layout from "@/layouts/Layout.astro";
import { essays } from "@/content/site";

export function getStaticPaths() {
  return essays.map((post) => ({
    params: { slug: post.href.split("/").at(-1) },
    props: { post }
  }));
}

const { post } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric"
}).format(new Date(`${post.date}T00:00:00`));
---

<Layout title={`${post.title} | Jon Cristinziano`} description={post.description} canonical={post.href}>
  <article class="readable py-12 md:py-16">
    <a class="focus-ring link-hover inline-flex items-center gap-2 text-sm font-semibold text-muted" href="/writing">
      <span aria-hidden="true">&larr;</span>
      <span>Writing</span>
    </a>
    <header class="mt-8 border-b border-border pb-8">
      <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-muted">
        <time datetime={post.date}>{formattedDate}</time>
        <span aria-hidden="true">·</span>
        <span>{post.readingTime}</span>
      </div>
      <h1 class="mt-5 text-3xl font-semibold leading-tight tracking-normal text-text md:text-4xl">{post.title}</h1>
      <p class="mt-5 text-base leading-7 text-muted">{post.description}</p>
    </header>

    <div class="mt-9 space-y-5 text-base leading-8 text-text">
      {post.body.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </article>
</Layout>
